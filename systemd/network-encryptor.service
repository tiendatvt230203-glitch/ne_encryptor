[Unit]
Description=Network Encryptor
After=network.target postgresql.service

[Service]
Type=simple
User=root
EnvironmentFile=/opt/SEP/be/.env
ExecStart=/usr/bin/bin-ne/network-encryptor
Restart=always
RestartSec=5s

[Install]
WantedBy=multi-user.target
